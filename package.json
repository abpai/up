{
  "name": "up",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "itty-router": "^5.0.23",
    "lucide-react": "^1.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-router-dom": "^7.13.2"
  },
  "scripts": {
    "dev": "concurrently \"pnpm run dev:worker\" \"pnpm run dev:app\"",
    "dev:app": "vite",
    "dev:worker": "wrangler dev --port 8787",
    "build": "vite build",
    "build:cli": "pnpm --filter @andypai/up run build",
    "build:all": "pnpm run build && pnpm run build:cli",
    "deploy": "pnpm run build && wrangler deploy",
    "preview": "vite preview",
    "preview:worker": "pnpm run build && wrangler dev",
    "test": "pnpm run test:app && pnpm run test:cli",
    "test:app": "vitest run",
    "test:cli": "pnpm --filter @andypai/up test",
    "lint": "eslint .",
    "fix": "pnpm run lint -- --fix"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-flowtype": "^8.0.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^29.0.1",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.2.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  }
}
